{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@umbra/plugin-sdk": [
        "../umbra-plugin-sdk/src/index"
      ],
      "@umbra/plugin-runtime": [
        "../umbra-plugin-runtime/src/index"
      ],
      "@umbra/service": [
        "../umbra-service/src/index"
      ],
      "@umbra/wasm": [
        "../umbra-wasm/index"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ],
  "exclude": [
    "node_modules",
    "../umbra-core",
    "../umbra-relay",
    "../umbra-bridge-bot",
    "../umbra-ghost-ai",
    "../umbra-uikit",
    "../umbra-wisps"
  ]
}
